{
  "name": "block-report",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file=.env --import=tsx --watch server/index.ts",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:server\"",
    "build": "vite build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:safe": "bash scripts/migrate-safe.sh",
    "db:push": "echo 'ERROR: db push is unsafe for production — use db:migrate instead' && exit 1",
    "db:seed": "node --env-file=.env --import=tsx scripts/seed.ts",
    "generate-reports": "node --env-file=.env --import=tsx server/scripts/generate-reports.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "mcp": "node --env-file=.env --import=tsx server/mcp/index.ts",
    "mcp:http": "node --env-file=.env --import=tsx server/mcp/http.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
