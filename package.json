    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "prisma": "^5.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "puppeteer-core": "^24.9.0",
    "qrcode": "^1.5.4",
    "@sparticuz/chromium": "^133.0.0",
    "ws": "^8.19.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@axe-core/react": "^4.11.1",
